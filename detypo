#!/usr/bin/env bash
# =============================================================================
# detypo — Detypo PDF Proofreader one-click launcher
# =============================================================================
# Usage:
#   ./detypo              Prod mode (build, serve at :3000) [default]
#   ./detypo dev           Dev mode (hot-reload, opens :4000)
#   ./detypo stop          Stop all services
#
# Requires: Python 3.10+, Node.js 18+
# =============================================================================

set -e

# ── CD to script directory ──
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

BACKEND_PORT=3000
FRONTEND_PORT=4000
FRONTEND_DIR="frontend"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[detypo]${NC} $1"; }
ok()    { echo -e "${GREEN}[detypo]${NC} $1"; }
warn()  { echo -e "${YELLOW}[detypo]${NC} $1"; }
err()   { echo -e "${RED}[detypo]${NC} $1"; }

# ── Find Python ──
PYTHON=""
for c in python python3; do
    if command -v "$c" &>/dev/null && "$c" --version &>/dev/null 2>&1; then
        PYTHON="$c"
        break
    fi
done
if [ -z "$PYTHON" ]; then
    err "Python not found. Please install Python 3.10+"
    exit 1
fi

# ── Kill port (Windows + Unix) ──
kill_port() {
    local port=$1 pid
    # Windows
    local pids
    pids=$(netstat -ano 2>/dev/null | grep ":${port} " | grep "LISTENING" | awk '{print $NF}' | sort -u)
    for pid in $pids; do
        [ -z "$pid" ] && continue
        [ "$pid" = "0" ] && continue
        taskkill //PID "$pid" //F //T >/dev/null 2>&1 || true
    done
    # Unix
    if command -v lsof &>/dev/null; then
        pid=$(lsof -ti :"${port}" 2>/dev/null)
        [ -n "$pid" ] && kill -9 "$pid" 2>/dev/null || true
    fi
    sleep 0.3
}

# ── Wait for service ──
wait_for() {
    local url=$1 name=$2 max=${3:-30} i=0 code
    info "Waiting for ${name}..."
    while [ $i -lt $max ]; do
        code=$(curl -s -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo "000")
        if [ "$code" != "000" ]; then
            ok "${name} ready"
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    warn "${name} may not be ready (timeout)"
    return 1
}

# ── Open browser ──
open_browser() {
    info "Opening browser: $1"
    cmd.exe /c start "$1" 2>/dev/null || xdg-open "$1" 2>/dev/null || open "$1" 2>/dev/null || true
}

# ── Install deps if needed ──
ensure_deps() {
    if ! "$PYTHON" -c "import fastapi, uvicorn, pymupdf, requests, pydantic" 2>/dev/null; then
        info "Installing Python dependencies..."
        pip install -r requirements.txt >/dev/null 2>&1 || {
            err "Python dep install failed. Check network."
            exit 1
        }
        ok "Python deps ready"
    fi
    if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
        info "Installing frontend dependencies..."
        (cd "$FRONTEND_DIR" && npm install --silent) || {
            err "Frontend dep install failed. Check network."
            exit 1
        }
        ok "Frontend deps ready"
    fi
}

# ── Cleanup ──
cleanup() {
    kill_port $BACKEND_PORT
    kill_port $FRONTEND_PORT
    taskkill //F //IM python.exe >/dev/null 2>&1 || true
    taskkill //F //IM node.exe >/dev/null 2>&1 || true
}

# ── stop ──
do_stop() {
    info "Stopping services..."
    cleanup
    ok "Stopped"
}

# ── Prod mode ──
do_prod() {
    info "Detypo - Prod Mode"
    ensure_deps
    cleanup 2>/dev/null
    sleep 0.5

    info "Building frontend..."
    (cd "$FRONTEND_DIR" && npm run build) || { err "Frontend build failed"; exit 1; }
    ok "Frontend build done"

    echo ""
    echo -e "${GREEN}======================================${NC}"
    echo -e "${GREEN}  Detypo is running (prod)${NC}"
    echo -e "${GREEN}  URL:  http://127.0.0.1:${BACKEND_PORT}${NC}"
    echo -e "${GREEN}  Stop: Ctrl+C or close this window${NC}"
    echo -e "${GREEN}======================================${NC}"
    echo ""
    open_browser "http://127.0.0.1:${BACKEND_PORT}"

    export DETYPO_PROD=1
    "$PYTHON" server.py
    echo ""
    info "Server stopped. Cleaning up..."
    cleanup
    ok "Done"
}

# ── Dev mode ──
do_dev() {
    info "Detypo - Dev Mode"
    ensure_deps
    cleanup 2>/dev/null
    sleep 0.5

    info "Starting backend (127.0.0.1:${BACKEND_PORT})..."
    "$PYTHON" server.py > /tmp/detypo-backend.log 2>&1 &
    echo $! > /tmp/detypo-port-${BACKEND_PORT}.pid
    wait_for "http://127.0.0.1:${BACKEND_PORT}" "Backend" 20

    info "Starting frontend (127.0.0.1:${FRONTEND_PORT})..."
    (cd "$FRONTEND_DIR" && npm run dev > /tmp/detypo-frontend.log 2>&1) &
    echo $! > /tmp/detypo-port-${FRONTEND_PORT}.pid
    wait_for "http://127.0.0.1:${FRONTEND_PORT}" "Frontend" 20

    echo ""
    echo -e "${GREEN}======================================${NC}"
    echo -e "${GREEN}  Detypo is running (dev)${NC}"
    echo -e "${GREEN}  URL:  http://127.0.0.1:${FRONTEND_PORT}${NC}"
    echo -e "${GREEN}  Stop: ./detypo stop${NC}"
    echo -e "${GREEN}======================================${NC}"
    echo ""
    open_browser "http://127.0.0.1:${FRONTEND_PORT}"
}

# ── Entry ──
case "${1:-prod}" in
    dev)  do_dev ;;
    prod) do_prod ;;
    stop) do_stop ;;
    *)
        echo "Usage: ./detypo {prod|dev|stop}"
        echo "  prod  Prod mode (default) — build and serve at :3000"
        echo "  dev   Dev mode — hot-reload, opens :4000"
        echo "  stop  Stop all services"
        exit 1
        ;;
esac
