#!/usr/bin/env bash
# =============================================================================
# detypo — 得误 Detypo PDF 校对助手 一键启动脚本
# =============================================================================
# 用法:
#   ./detypo             生产模式（构建前端，后端统一服务）默认
#   ./detypo dev          开发模式（前后端分别启动，热重载）
#   ./detypo stop         停止所有 detypo 进程
#
# 首次运行会自动安装依赖。需要 Python 3.10+ 和 Node.js 18+。
# 服务就绪后自动打开浏览器访问 http://127.0.0.1:4000
#
# 支持: Windows (Git Bash) / macOS / Linux
# =============================================================================

# ── 自定位到脚本所在目录 ──
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

BACKEND_PORT=3000
FRONTEND_PORT=4000
FRONTEND_DIR="frontend"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}[detypo]${NC} $1"; }
ok()    { echo -e "${GREEN}[detypo]${NC} ✓ $1"; }
warn()  { echo -e "${YELLOW}[detypo]${NC} ⚠ $1"; }
err()   { echo -e "${RED}[detypo]${NC} ✗ $1"; }

# ── 检测 Python ──
PYTHON=""
for c in python python3; do
    if command -v "$c" &>/dev/null && "$c" --version &>/dev/null 2>&1; then
        PYTHON="$c"
        break
    fi
done
if [ -z "$PYTHON" ]; then
    err "未找到 Python，请安装 Python 3.10+"
    exit 1
fi

# ── 端口处理 ──
kill_port() {
    local port=$1 pid
    # Kill by known PID file first
    if [ -f "/tmp/detypo-port-${port}.pid" ]; then
        pid=$(cat "/tmp/detypo-port-${port}.pid" 2>/dev/null)
        if [ -n "$pid" ]; then
            taskkill //PID "$pid" //F //T >/dev/null 2>&1 || true
            rm -f "/tmp/detypo-port-${port}.pid"
        fi
    fi
    # Then kill anything still on the port
    local pids
    pids=$(netstat -ano 2>/dev/null | grep ":${port} " | grep "LISTENING" | awk '{print $NF}' | sort -u)
    for pid in $pids; do
        [ -z "$pid" ] && continue
        [ "$pid" = "0" ] && continue
        taskkill //PID "$pid" //F //T >/dev/null 2>&1 || true
    done
    sleep 0.3
}

# ── 等待服务就绪 ──
wait_for() {
    local url=$1 name=$2 max=${3:-30} i=0 code
    info "等待 ${name} 就绪..."
    while [ $i -lt $max ]; do
        code=$(curl -s -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo "000")
        if [ "$code" != "000" ]; then
            ok "${name} 已就绪"
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done
    warn "${name} 可能未就绪 (超时)"
    return 1
}

# ── 打开浏览器 ──
open_browser() {
    info "打开浏览器 $1 ..."
    cmd.exe /c start "$1" 2>/dev/null || xdg-open "$1" 2>/dev/null || open "$1" 2>/dev/null || true
}

# ── stop ──
do_stop() {
    info "停止服务..."
    kill_port $BACKEND_PORT
    kill_port $FRONTEND_PORT
    ok "已停止"
}

# ── 安装依赖 (如果需要) ──
ensure_deps() {
    # Python dep check: try importing key packages
    if ! "$PYTHON" -c "import fastapi, uvicorn, pymupdf, requests, pydantic" 2>/dev/null; then
        info "安装 Python 依赖..."
        pip install -r requirements.txt >/dev/null 2>&1 || {
            err "Python 依赖安装失败，请检查网络后重试"
            exit 1
        }
        ok "Python 依赖就绪"
    fi
    # Frontend dep check
    if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
        info "安装前端依赖..."
        (cd "$FRONTEND_DIR" && npm install --silent) || {
            err "前端依赖安装失败，请检查网络后重试"
            exit 1
        }
        ok "前端依赖就绪"
    fi
}

# ── 开发模式 ──
do_dev() {
    info "得误 Detypo — 开发模式"
    ensure_deps
    do_stop 2>/dev/null
    sleep 0.5

    info "启动后端 (127.0.0.1:${BACKEND_PORT})..."
    "$PYTHON" server.py > /tmp/detypo-backend.log 2>&1 &
    echo $! > /tmp/detypo-port-${BACKEND_PORT}.pid
    wait_for "http://127.0.0.1:${BACKEND_PORT}" "后端" 20

    info "启动前端 (127.0.0.1:${FRONTEND_PORT})..."
    (cd "$FRONTEND_DIR" && npm run dev > /tmp/detypo-frontend.log 2>&1) &
    echo $! > /tmp/detypo-port-${FRONTEND_PORT}.pid
    wait_for "http://127.0.0.1:${FRONTEND_PORT}" "前端" 20

    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  得误 Detypo 已启动 ✨${NC}"
    echo -e "${GREEN}  地址: http://127.0.0.1:${FRONTEND_PORT}${NC}"
    echo -e "${GREEN}  停止: ./detypo stop${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    open_browser "http://127.0.0.1:${FRONTEND_PORT}"
}

# ── 生产模式 ──
do_prod() {
    info "得误 Detypo — 生产模式"
    ensure_deps
    do_stop 2>/dev/null
    sleep 0.5

    info "构建前端..."
    (cd "$FRONTEND_DIR" && npm run build) || { err "前端构建失败"; exit 1; }
    ok "前端构建完成"

    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  得误 Detypo 已启动 (生产)${NC}"
    echo -e "${GREEN}  地址: http://127.0.0.1:${BACKEND_PORT}${NC}"
    echo -e "${GREEN}  停止: Ctrl+C${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    "$PYTHON" server.py
}

# ── 入口 ──
case "${1:-prod}" in
    dev)  do_dev ;;
    prod) do_prod ;;
    stop) do_stop ;;
    *)
        echo "用法: ./detypo {prod|dev|stop}"
        echo "  prod  生产模式（默认）— 构建前端后统一服务，浏览器访问 :3000"
        echo "  dev   开发模式 — 前后端热重载，浏览器访问 :4000"
        echo "  stop  停止所有服务"
        exit 1
        ;;
esac
